GIN_MODE="release"
APP_NAME="pharma-crm-backend"
APP_VERSION="1.0.0"
APP_ENV="DEV"
LOG_LEVEL="debug"

# SERVER PORT
HTTP_PORT="8090"

# POSTGRES
PG_POOL_MAX=2
PG_HOST="localhost"
PG_PORT="5432"
PG_USER="user"
PG_PASS="password"
PG_DB="dbname"
DB_URL="postgresql://user:password@localhost:5432/dbname?sslmode=disable"

# JWT SECRET
SECRET_KEY="secret"

# HASH KEY
HASH_KEY="hash-key"

# External API basic auth
EXTERNAL_API_USERNAME="username"
EXTERNAL_API_PASSWORD="password"

# Click
CLICK_API_URL="https://api.click.uz/v2/merchant"

# Payme Go
PAYME_API_URL="https://checkout.paycom.uz/api"

# Uzum
UZUM_API_URL="https://mobile.apelsin.uz/api/apelsin-pay/merchant"

# Alif
ALIF_API_URL="https://api-dev.alifpay.uz"
ALIF_API_TOKEN="+eCcwx2YWDU1zkqQJe0BCZaBLgWSrx8yOLF15PjG2WMD"

# 1C
ONEC_API_URL="test"
ONEC_API_USERNAME="username"
ONEC_API_PASSWORD="password"
ONEC_PASSWORD="password"

# Tasnif
TASNIF_API_URL="https://tasnif.soliq.uz/api/cls-api/attribute"

# Noor 
NOOR_API_URL="https://tback.noor.uz/api/v1"
NOOR_API_TOKEN="token"

# Dmed
DMED_API_URL="https://rosa.test.dmed.uz/api/integrations"
DMED_API_TOKEN="token"

# OAuth2 Configuration
UZUM_CLIENT_ID="uzum_client_id"
UZUM_CLIENT_SECRET="uzum_client_secret"
OAUTH_TOKEN_EXPIRY=3600